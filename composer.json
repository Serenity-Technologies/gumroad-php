{
    "name": "serenity-technologies-library/gumroad",
    "description": "Laravel package for Gumroad API integration with DTOs and QueryBuilders",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kwadwo Kyeremeh",
            "email": "kyerematics@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/support": "^9.0|^10.0|^11.0",
        "illuminate/http": "^9.0|^10.0|^11.0",
        "spatie/laravel-data": "^4.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "mockery/mockery": "^1.4"
    },
    "autoload": {
        "psr-4": {
            "Gumroad\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gumroad\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gumroad\\GumroadServiceProvider"
            ],
            "aliases": {
                "Gumroad": "Gumroad\\Facades\\Gumroad"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
